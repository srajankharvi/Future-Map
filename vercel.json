{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/frontend/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/frontend/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}